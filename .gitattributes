# Normalize line endings per file type
*.go     text eol=lf
*.sh     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.ps1    text eol=crlf
*.psm1   text eol=crlf
*.psd1   text eol=crlf

# Binary files — never touch
*.exe    binary
*.tar.gz binary
*.zip    binary
*.png    binary
*.jpg    binary
*.ico    binary

# Git-specific
*.gitattributes text
*.gitignore     text
